# Copy this to .env and fill in values for local dev.
# .env is gitignored — never commit real secrets.

# --- App ---
LOG_LEVEL=INFO
# Where the SQLite DB lives. Defaults to ./data/tag_inventory.db relative to cwd.
# DATABASE_URL=sqlite:///./data/tag_inventory.db

# --- Shopify (Phase 2/5) ---
# See claude_documents/test_accounts_setup.md §1
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# --- eBay (Phase 2) ---
# See claude_documents/test_accounts_setup.md §2
EBAY_ENV=sandbox
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_REFRESH_TOKEN=
EBAY_SANDBOX_USERNAME=

# --- TCGPlayer (Phase 1) ---
# See claude_documents/test_accounts_setup.md §3
TCGPLAYER_PRO_USERNAME=
TCGPLAYER_PRO_PASSWORD=

# Seller identity on TCGPlayer's public marketplace. Both IDs travel
# together — the numeric SellerId is internal, the SellerKey is what the
# search API filters on (listingSearch.filters.term.sellerKey).
# Pulled from the SellerFilter cookie when logged in as the seller.
TCGPLAYER_SELLER_ID=734972
TCGPLAYER_SELLER_KEY=1d1b3bf6
TCGPLAYER_SELLER_NAME=Tag Collects

# How long the "Get from TCGPlayer Portal" button waits for the user to
# log in (seconds). Default 900 (15 minutes). Bump higher if your auth
# flow includes 2FA / email codes / a slow password manager.
TCGPLAYER_PORTAL_LOGIN_WAIT_SEC=900

# How long to wait for the CSV to materialize after clicking "Export
# From Live" (seconds). Default 180. The full-catalog export at
# ~219K rows takes ~30s to materialize on TCGPlayer's side.
TCGPLAYER_PORTAL_DOWNLOAD_TIMEOUT_SEC=180
